{
  "projectRulesFile": "CLAUDE.md",
  "architectureFile": ".claude/docs/ARCHITECTURE.md",
  "progressDir": ".claude/progress",
  "branching": {
    "baseBranch": "auto",
    "featurePrefix": "feature",
    "workPrefix": "work",
    "enforce": "warn",
    "protectedBranches": [
      "main",
      "master"
    ],
    "useWorktrees": true,
    "worktreeDir": ".worktrees"
  },
  "guards": {
    "branchGuard": false,
    "destructiveGuard": true,
    "configGuard": false,
    "workflowGate": false,
    "teamLeaderGate": false,
    "enforcementGate": false
  }
}
